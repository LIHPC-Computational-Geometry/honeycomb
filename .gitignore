# Rust
/.cargo
/vendor
/target

# local IDE configs
/.idea
/.vscode

# ignore csv, svg, txt, zip files in root directory, cluster log files
/*.csv
/*.svg
/*.txt
/*.zip
/*.e
/*.o

# ignore wild vtk files
*.vtk
!/applications/shape.vtk

# shell files (mostly cluster-related)
/*.sh
!/applications/scripts/*.sh

# ignore coverage-related files
*.profraw
*.lcov

# perf
perf.data
perf.data.old
# heaptrack
*.zst
# sa;ply
*.json.gz

# ignore bench result directories
/fixed
/grid
/thread
/out
